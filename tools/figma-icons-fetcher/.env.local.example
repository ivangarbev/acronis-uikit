# Figma API Token - Get from https://www.figma.com/developers/api#access-tokens
FIGMA_FETCHER_FIGMA_TOKEN="your-figma-token-here"

# Figma File Key - Extract from Figma file URL
# Example: https://www.figma.com/file/ABC123/My-Icons -> ABC123
FIGMA_FETCHER_FILE_KEY="your-file-key-here"

# Page names containing icons (comma-separated)
FIGMA_FETCHER_PAGE_NAMES="Icons, Design System"

# Frame names containing icons (comma-separated)
FIGMA_FETCHER_FRAME_NAMES="16px, 24px, 32px"

# CSS class name to add to SVG elements (leave empty for no class)
FIGMA_FETCHER_CLASS_NAME=""

# Color to replace with currentColor (hex format)
FIGMA_FETCHER_SYSTEM_COLOR="#181818"

# Output directory for downloaded SVG files
FIGMA_FETCHER_OUTPUT_DIR="./icons"

# Additional output directories (comma-separated, optional)
# Icons will be saved to all specified directories
FIGMA_FETCHER_OUTPUT_DIRS=""

# Generate JSON manifest files (true/false)
FIGMA_FETCHER_GENERATE_MANIFESTS="false"

# Directory for JSON manifest files
FIGMA_FETCHER_MANIFEST_DIR="./manifests"

# Categorize icons by color type (true/false)
# When enabled, saves monocolor and multicolor icons to separate directories
FIGMA_FETCHER_CATEGORIZE_BY_COLOR="false"

# Directory for monocolor icons (when categorization is enabled)
FIGMA_FETCHER_MONOCOLOR_DIR="monocolor-icons"

# Directory for multicolor icons (when categorization is enabled)
FIGMA_FETCHER_MULTICOLOR_DIR="multicolor-icons"
