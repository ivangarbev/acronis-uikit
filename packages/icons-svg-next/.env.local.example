# Figma Icons Fetcher configuration for the icons-svg-next package.
# Copy this file to .env.local and fill in your Figma token, then run:
#   pnpm --filter @acronis-platform/icons-svg-next pull-icons

# Figma API Token - Get from https://www.figma.com/developers/api#access-tokens
FIGMA_FETCHER_FIGMA_TOKEN="your-figma-token-here"

# Figma File Key - the shadcn-uikit file
FIGMA_FETCHER_FILE_KEY="lrU3ydIyvPYQNE6ixdsKtJ"

# The "icon-packs-source" section node (from the Figma URL's node-id). Pulled
# directly, so no page name is needed. URL form "2246-3201" also works.
FIGMA_FETCHER_NODE_ID="2246:3201"

# Selection strategy: the section's four top-level frames are the packs
# (stroke-mono, stroke-multi, solid-mono, solid-multi); each becomes a manifest
# group, and `_iconsource/<Name>` components inside become icons.
FIGMA_FETCHER_SELECTION_STRATEGY="icon-packs"

# CSS class name to add to SVG elements (leave empty for no class)
FIGMA_FETCHER_CLASS_NAME=""

# Color to replace with currentColor (hex format) — the redesign stroke color.
FIGMA_FETCHER_SYSTEM_COLOR="#1763CF"

# The source canvas is a live WIP surface with some empty placeholder frames
# Figma cannot render — skip them instead of failing the whole sync.
FIGMA_FETCHER_SKIP_MISSING_IMAGES="true"

# Primary output directory for all SVG files
FIGMA_FETCHER_OUTPUT_DIR="./src/svg"

# Additional output directories (optional, comma-separated)
FIGMA_FETCHER_OUTPUT_DIRS=""

# Generate JSON manifest files (true/false) — one per pack + combined icons.json
FIGMA_FETCHER_GENERATE_MANIFESTS="true"

# Directory for JSON manifest files
FIGMA_FETCHER_MANIFEST_DIR="./src/figma"

# Wipe the manifest dir before regenerating so renamed/removed packs and
# categories don't leave stale manifests behind (src/figma is generated-only).
FIGMA_FETCHER_CLEAN_MANIFESTS="true"

# No mono/multicolor split — this package keeps a single flat src/svg set.
FIGMA_FETCHER_CATEGORIZE_BY_COLOR="false"
