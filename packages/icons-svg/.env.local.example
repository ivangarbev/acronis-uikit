# Figma Icons Fetcher configuration for the icons-svg package.
# Copy this file to .env.local and fill in your Figma token, then run:
#   pnpm --filter @acronis-platform/icons-svg pull-icons

# Figma API Token - Get from https://www.figma.com/developers/api#access-tokens
FIGMA_FETCHER_FIGMA_TOKEN="your-figma-token-here"

# Figma File Key - Extract from the Figma file URL
FIGMA_FETCHER_FILE_KEY="SeWLzXxzzYfvfjzzbTYUl1"

# Page names containing icons (comma-separated)
FIGMA_FETCHER_PAGE_NAMES="Monocolor - Actions,Monocolor - Arrows,Monocolor - Brands+Products,Monocolor - Common,Monocolor - File types,Multicolor - Status,Multicolor - Tray Center"

# Frame names containing icons (comma-separated)
FIGMA_FETCHER_FRAME_NAMES="16px,24px,32px,72px,96px"

# CSS class name to add to SVG elements (leave empty for no class)
FIGMA_FETCHER_CLASS_NAME=""

# Color to replace with currentColor (hex format)
FIGMA_FETCHER_SYSTEM_COLOR="#2668C5"

# Primary output directory for all SVG files
FIGMA_FETCHER_OUTPUT_DIR="./src/svg"

# Additional output directories (optional, comma-separated)
FIGMA_FETCHER_OUTPUT_DIRS=""

# Generate JSON manifest files (true/false)
FIGMA_FETCHER_GENERATE_MANIFESTS="true"

# Directory for JSON manifest files
FIGMA_FETCHER_MANIFEST_DIR="./src/figma"

# Categorize icons by color type (true/false)
FIGMA_FETCHER_CATEGORIZE_BY_COLOR="true"

# Directory for monocolor icons
FIGMA_FETCHER_MONOCOLOR_DIR="./src/monocolor-icons"

# Directory for multicolor icons
FIGMA_FETCHER_MULTICOLOR_DIR="./src/multicolor-icons"
