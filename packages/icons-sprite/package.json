{
  "name": "@acronis-platform/icons-sprite",
  "version": "0.2.0",
  "description": "Optimized SVG sprites (combined / monocolor / multicolor) generated from @acronis-platform/icons-svg.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "sprites/**/*.svg",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./iconsprite.svg": "./sprites/iconsprite.svg",
    "./iconsprite-mono.svg": "./sprites/iconsprite-mono.svg",
    "./iconsprite-multi.svg": "./sprites/iconsprite-multi.svg"
  },
  "scripts": {
    "build": "tsx scripts/generate-sprite.ts",
    "dev": "echo \"no dev (generated artifacts; run build)\" && exit 0",
    "clean": "echo \"no clean (generated sprites are committed; run build to regenerate)\" && exit 0",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "pnpm run build",
    "test:watch": "echo \"no watch mode (run test)\" && exit 0",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "acronis",
    "icons",
    "sprite",
    "svg",
    "design-system"
  ],
  "devDependencies": {
    "@acronis-platform/icons-svg": "workspace:*",
    "@types/node": "catalog:",
    "cheerio": "^1.0.0",
    "svgo": "catalog:",
    "tsx": "^4.20.0",
    "typescript": "catalog:"
  }
}
